# === Base de Datos ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sgai

# === DeepSeek API ===
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# === Telegram Bot ===
# Poner false para correr SGAI como API pura (sin bot activo)
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# === Integración Ana (OpenClaw) ===
# API key que Ana incluye en el header X-Ana-Key para llamar a SGAI
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ANA_API_KEY=generate-a-secure-random-key

# URL del gateway de OpenClaw (Ana) para alertas salientes de SGAI → Ana
# En producción (mismo VPS): http://localhost:18789/  (ajustar path según endpoint del gateway)
# En desarrollo (Ana en VPS, SGAI en WSL con túnel): https://tu-tunel.trycloudflare.com/
OPENCLAW_WEBHOOK_URL=http://localhost:18789/

# Clave que SGAI incluye en X-SGAI-Key al llamar a Ana (debe coincidir con lo configurado en Ana)
SGAI_OUTBOUND_KEY=generate-a-secure-random-key

# === Seguridad ===
JWT_SECRET_KEY=generate-a-secure-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# === App ===
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
APP_VERSION=1.0.0
